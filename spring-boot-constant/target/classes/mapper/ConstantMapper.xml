<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mozisun.springbootconstant.mapper.ConstantMapper">

  <resultMap id="ConstantResultMap" type="com.mozisun.springbootconstant.model.Constant">
    <id     column="constant_id"  property="constantId" />
    <result column="category_code" property="categoryCode" />
    <result column="code"         property="code" />
    <result column="name"         property="name" />
    <result column="status"       property="status" />
    <result column="sort_order"   property="sortOrder" />
  </resultMap>

  <select id="selectAllEnabled" resultMap="ConstantResultMap">
    SELECT * FROM t_constant WHERE status = 1 ORDER BY category_code, sort_order
  </select>

  <select id="selectByCategory" parameterType="string" resultMap="ConstantResultMap">
    SELECT * FROM t_constant
    WHERE category_code = #{category} AND status = 1
    ORDER BY sort_order
  </select>


</mapper>